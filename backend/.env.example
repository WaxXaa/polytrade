# Server
PORT=3000
HOST=0.0.0.0

# Database (SQLite via LibSQL)
DB_PATH=file:data/agent.db

# Polymarket CLOB API credentials
CLOB_API_KEY=your_api_key_here
CLOB_SECRET=your_api_secret_here
CLOB_PASSPHRASE=your_api_passphrase_here

# Wallet private key (for real trading mode)
PRIVATE_KEY=your_private_key_here

# AWS Secrets Manager (optional, for production)
# AWS_SECRET_NAME=polymarket-agent/production
# AWS_REGION=us-east-1
